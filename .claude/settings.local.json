{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"C:/Users/MAX/Downloads/claude\" && git add -A && git diff --cached --quiet || (git commit -m \"auto: save changes\" && export PATH=\"/c/Program Files/GitHub CLI:$PATH\" && git push) 2>/dev/null || true",
            "statusMessage": "Saving to GitHub..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(npm create:*)",
      "Read(//c/Users/MAX/AppData/Roaming/**)",
      "Read(//c/Program Files/**)",
      "Bash(cmd /c \"node --version\")",
      "Bash(cmd /c \"npm --version\")",
      "Read(//c/Users/MAX/AppData/Local/Programs//**)",
      "Read(//c/Users/MAX/**)",
      "Bash(export PATH=\"/c/Program Files/nodejs:$PATH\")",
      "Bash(npm --version)",
      "Bash(npm install:*)",
      "mcp__Claude_Preview__preview_start",
      "Bash(ls C:/Users/MAX/Downloads/claude/node_modules/.bin/vite*)",
      "Bash(powershell.exe -Command \"winget install GitHub.cli --accept-package-agreements --accept-source-agreements\")",
      "Bash(export PATH=\"/c/Program Files/GitHub CLI:$PATH\")",
      "Bash(gh --version)",
      "Bash(gh auth:*)"
    ]
  }
}

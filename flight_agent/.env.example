# Amadeus API (free at developers.amadeus.com)
AMADEUS_CLIENT_ID=your_api_key_here
AMADEUS_CLIENT_SECRET=your_api_secret_here

# Gmail - use App Password (not your regular password)
# How to get: Google Account → Security → 2-Step Verification → App passwords
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Check time (24h format)
CHECK_TIME=09:00
